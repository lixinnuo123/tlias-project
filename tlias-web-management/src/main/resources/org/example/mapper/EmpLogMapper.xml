<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.EmpLogMapper">

    <!-- 分页查询操作日志 -->
    <select id="list" resultType="org.example.pojo.EmpLog">
        select
            el.id,
            el.emp_id empId,
            e.name operateName,
            el.operate_time operateTime,
            el.info
        from emp_log el
                 left join emp e on el.emp_id = e.id
        order by el.operate_time desc
    </select>

    <!-- 查询总记录数 -->
    <select id="count" resultType="java.lang.Long">
        select count(*) from emp_log
    </select>
</mapper>
